ENV_STATE=local
DEBUG=true

# REDIS CONNECTION
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# === LOGGING SETTINGS ===
LOG_LEVEL=INFO
LOG_JSON_FORMAT=False
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_DIR=/logs

# === TEST SETTINGS ===
# Set to true to run tests on startup
RUN_TESTS=false
# Options: unit, integration, security, all
TEST_TYPE=all
# Set to true to fail container startup on test failures
FAIL_ON_TEST_FAILURE=false
